rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Payday Checklist — only Gray's Google account can touch the data.
    // The web config in firebase-config.js is public by design; THIS is the lock.
    match /households/gray/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'graydavis33@gmail.com'
        && request.auth.token.email_verified == true;
    }
  }
}
