    },
    {
      "start": 87.6,
      "end": 88.4,
      "text": "You're 31 years old?"
    },
    {
      "start": 88.5,
      "end": 88.8,
      "text": "I am."
    },
    {
      "start": 89.0,
      "end": 89.9,
      "text": "I'm proud of you, man."
    },
    {
      "start": 90.1,
