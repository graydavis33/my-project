    {
      "start": 0.0,
      "end": 2.1,
      "text": "Excuse me sir, sir, are you a millionaire?"
    },
    {
      "start": 2.8,
      "end": 3.4,
      "text": "Not anymore."
    },
    {
      "start": 3.8,
      "end": 4.3,
      "text": "Did you go broke?"
    },
